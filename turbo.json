{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["pnpm-lock.yaml"],
  "tasks": {
    "build": {
      "inputs": ["app/**", "public/**", "nuxt.config.ts", "i18n.config.ts"],
      "env": ["NUXT_APP_BASE_URL"],
      "outputs": [".nuxt/**", ".output/**", "dist/**"]
    },
    "lint": {
      "inputs": [
        ".editorconfig",
        ".prettierrc",
        ".prettierignore",
        "app/**",
        "public/**",
        "nuxt.config.ts",
        "i18n.config.ts"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
